    {
      "id": "comet",
      "name": "Comet",
      "names": {
        "en": "Comet",
        "ru": "Комета",
        "zh": "彗星",
        "es": "Cometa",
        "ar": "مذنب",
        "fr": "Comète"
      },
      "tagline": "Bend gravity. Thread the needle. Reach the gate.",
      "style": "neon-vector",
      "styles": [
        "vector",
        "glow",
        "smooth-canvas",
        "shader-bg"
      ],
      "genres": [
        "arcade",
        "puzzle",
        "physics"
      ],
      "controls": {
        "primary": "touch",
        "supported": [
          "touch",
          "mouse"
        ],
        "keyboard": "none",
        "mouse": "ok",
        "notes": {
          "en": "Tap or click to place gravity wells. No keyboard.",
          "ru": "Тап или клик — гравиколодец. Клавиатура не нужна."
        }
      },
      "parameters": {
        "difficulty": {
          "type": "enum",
          "default": "normal",
          "options": [
            "easy",
            "normal",
            "hard"
          ],
          "affects": [
            "wellsPerLevel",
            "cometSpeedMult",
            "maxSpeed",
            "wellLifeSec",
            "wellStrength",
            "hazardScale"
          ],
          "labels": {
            "en": "Difficulty (wells + comet speed)",
            "ru": "Сложность (колодцы + скорость кометы)"
          }
        },
        "wellsPerLevel": {
          "type": "derived",
          "description": {
            "en": "ceil(baseWells * mult) + bonus — Easy gives more charges",
            "ru": "ceil(base * mult) + bonus — на Easy больше зарядов колодцев"
          }
        },
        "cometSpeedMult": {
          "type": "derived",
          "description": {
            "en": "Easy 0.72 · Normal 1.0 · Hard 1.28 — multiplies start velocity",
            "ru": "Easy 0.72 · Normal 1.0 · Hard 1.28 — множитель стартовой скорости"
          }
        }
      },
      "tags": [
        "gravity",
        "touch",
        "levels",
        "solo",
        "experimental"
      ],
      "instructions": {
        "en": "Pick difficulty (wells budget). Tap to place gravity wells. Pull the comet into the cyan portal. Grab stars for points and extra wells. Avoid red singularities, walls, and the void beyond the screen.",
        "ru": "Выбери сложность (сколько колодцев). Тап — гравиколодец. Доведи комету до портала. Звёзды = очки и заряды. Красные дыры, стены, вылет — проигрыш."
      },
      "instructionsLong": {
        "en": "Wells last a few seconds and cost one charge. Stars restore a charge. Five levels of rising complexity. Solo only for now.",
        "ru": "Колодцы живут несколько секунд и тратят заряд. Звёзды возвращают заряд. Пять уровней. Пока только соло."
      },
      "authorId": "ogh-team",
      "authorInline": null,
      "dates": {
        "added": "2026-07-10",
        "updated": "2026-07-10",
        "released": "2026-07-10"
      },
      "familyId": "comet",
      "variantOf": null,
